# =====================================================
# BLOO CRM BACKEND ENVIRONMENT CONFIGURATION
# =====================================================

# Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Application URLs
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000/api

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/bloo-crm
MONGODB_NAME=bloo-crm

# =====================================================
# OAUTH PROVIDERS - GMAIL
# =====================================================
GMAIL_CLIENT_ID=YOUR_GMAIL_CLIENT_ID.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=YOUR_GMAIL_CLIENT_SECRET

# =====================================================
# OAUTH PROVIDERS - OUTLOOK
# =====================================================
OUTLOOK_CLIENT_ID=YOUR_OUTLOOK_CLIENT_ID
OUTLOOK_CLIENT_SECRET=YOUR_OUTLOOK_CLIENT_SECRET

# =====================================================
# OAUTH PROVIDERS - PROTONMAIL
# =====================================================
PROTONMAIL_CLIENT_ID=YOUR_PROTONMAIL_CLIENT_ID
PROTONMAIL_CLIENT_SECRET=YOUR_PROTONMAIL_CLIENT_SECRET

# =====================================================
# ENCRYPTION
# =====================================================
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-for-credentials

# =====================================================
# SESSION CONFIGURATION
# =====================================================
SESSION_SECRET=your-session-secret-key
SESSION_TIMEOUT=1800000

# =====================================================
# EMAIL CONFIGURATION
# =====================================================
DEFAULT_FROM_EMAIL=noreply@bluocrm.com
DEFAULT_FROM_NAME=Bloo CRM

# =====================================================
# FEATURE FLAGS
# =====================================================
ENABLE_OAUTH=true
ENABLE_EMAIL_SYNC=true
ENABLE_SMTP_PROVIDER=true
